{
  "name": "fluxo-finance-api",
  "private": true,
  "type": "module",
  "description": "API REST (Hono) com MySQL. Copie env.example para .env, defina DB_HOST, DB_USER, DB_PASSWORD, DB_NAME e CORS_ORIGIN; npm run dev. No app web use VITE_FINANCE_API_URL=http://localhost:8787",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.6.1",
    "hono": "^4.10.4",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^22.16.5",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
